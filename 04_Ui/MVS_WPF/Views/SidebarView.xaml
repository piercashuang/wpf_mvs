<UserControl x:Class="MVS_WPF.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vms="clr-namespace:MVS_WPF.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="250">

    <UserControl.DataContext>
        <vms:SidebarViewModel />
    </UserControl.DataContext>

    <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="0,0,1,0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="设备列表" Foreground="LightGray" Margin="15,10" FontSize="16" FontWeight="Bold"/>

            <Button Grid.Row="1" 
                    Content="扫描设备" 
                    Command="{Binding ScanCamerasCommand}" 
                    Height="30" 
                    Margin="15,0,15,10"
                    Background="#333333" Foreground="White" BorderBrush="#555555"/>

            <ListBox Grid.Row="2" 
                     ItemsSource="{Binding CameraList}" 
                     Background="Transparent" 
                     Foreground="LightGray" 
                     BorderThickness="0"
                     Margin="10,0,10,10"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3F3F46"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                </ListBox.Resources>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5,8" Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollContentPresenter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="📷 " Foreground="#FF8C00" FontSize="14" VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" FontSize="13" 
                       Margin="0,0,10,0" TextTrimming="CharacterEllipsis"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">

                                <Button Content="▶" ToolTip="连接相机" Background="Transparent" Foreground="LightGreen" BorderThickness="0" Margin="2,0" Cursor="Hand"
                        Command="{Binding DataContext.ConnectCameraCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>

                                <Button Content="⏹" ToolTip="断开相机" Background="Transparent" Foreground="#FF5555" BorderThickness="0" Margin="2,0" Cursor="Hand"
                        Command="{Binding DataContext.DisconnectCameraCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}"/>

                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Border>
</UserControl>